{
  "buildCommand": "npm run build",
  "outputDirectory": "busgo-bulgaria/dist",
  "rewrites": [
    { "source": "/health", "destination": "/api/index" },
    { "source": "/auth/:path*", "destination": "/api/index" },
    { "source": "/assistant", "destination": "/api/index" },
    { "source": "/cities", "destination": "/api/index" },
    { "source": "/routes/:path*", "destination": "/api/index" },
    { "source": "/routes", "destination": "/api/index" },
    { "source": "/admin/:path*", "destination": "/api/index" },
    { "source": "/seats/:path*", "destination": "/api/index" },
    { "source": "/bookings/:path*", "destination": "/api/index" },
    { "source": "/bookings", "destination": "/api/index" },
    { "source": "/payments", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
